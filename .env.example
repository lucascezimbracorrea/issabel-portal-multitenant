# apps/web (Vite) — set in Vercel → Project → Environment Variables (Production + Preview)
VITE_ISSABEL_BASE_URL=
# VITE_BASE=/console/
# VITE_API_URL=/api

# apps/api
PORT=8787
NODE_ENV=development
INTERNAL_TELEPHONY_TOKEN=change-me-in-production

# Portal app database (MySQL) — not the Issabel CDR database
DB_HOST=localhost
DB_PORT=3306
DB_USER=portal
DB_PASSWORD=
DB_NAME=issabel_portal

# JWT — gerar com: openssl rand -base64 48
JWT_SECRET=change-this-to-a-random-secret-min-32-chars

# CORS — separar por vírgula para múltiplos domínios
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Crons (Vercel) — Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# LensLead → portal (Edge Function portal-sync)
PORTAL_SYNC_SECRET=
LENSLEAD_FUNCTIONS_URL=https://YOUR_PROJECT.supabase.co/functions/v1

# Hotelaria — senhas SIP de hóspedes (min. 16 caracteres)
CREDENTIALS_ENCRYPTION_KEY=

# Filas — AMI opcional (preferir queue_log via CDR da org)
# AMI_HOST=
# AMI_PORT=5038
# AMI_USER=
# AMI_SECRET=

# E2E Playwright (opcional)
# E2E_BASE_URL=http://localhost:5173
